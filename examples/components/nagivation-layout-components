center;\n  border:1px solid var(--app-line-strong);border-radius:10px;\n  background:#fff;color:var(--app-text);font-size:0;\n  box-shadow:0 5px 16px rgba(15,23,42,.10);\n  transition:left .2s ease,background .16s ease,border-color .16s ease,transform .16s ease;\n}\n.hp-sidebar-toggle:hover{border-color:#93b4ec;background:var(--app-primary-soft);transform:translateY(-1px)}\n.hp-sidebar-toggle::before{content:\"☰\";font-size:17px;font-weight:800;color:var(--app-primary);line-height:1}\n.hyperpbi-root:has(.hp-shell.hp-with-sidebar) .hp-sidebar-toggle{left:238px}\n.hyperpbi-root:has(.hp-shell.hp-with-sidebar) .hp-sidebar-toggle::before{content:\"‹\";font-size:26px;font-weight:500}\n.hp-card{border:1px solid var(--app-line);border-radius:12px;background:#fff;box-shadow:0 5px 18px rgba(15,23,42,.045)}\n.hp-card-header{min-height:42px;padding:10px 14px;border-bottom:1px solid #e7edf4}\n.hp-card-header h3,.hp-section-title{font-size:12px;font-weight:700;letter-spacing:0;color:var(--app-text);text-transform:none}\n.hp-card-body{padding:14px}\n.hp-component{min-width:0}\n.hp-main>.hp-grid>.hp-component-html:first-child{grid-column:1/-1}\n.hp-tabs .nav-tabs{gap:4px;border-bottom:1px solid var(--app-line)}\n.hp-tabs .nav-link{margin:0;padding:9px 13px;border:0;border-bottom:2px solid transparent;background:transparent;color:#64748b;font-size:12px;font-weight:650}\n.hp-tabs .nav-link:hover{color:var(--app-text);background:#f8fafc}\n.hp-tabs .nav-link.active{border-bottom-color:var(--app-primary);background:transparent;color:var(--app-primary)}\n.hp-tab-content{padding-top:14px}\n.hp-control{gap:6px;color:#475569;font-size:11px;font-weight:600}\n.hp-control input,.hp-control select{min-height:38px;border-color:var(--app-line-strong);border-radius:9px;background:#fff;color:var(--app-text)}\n.hp-control input:focus,.hp-control select:focus{border-color:#7aa2ed;box-shadow:0 0 0 3px rgba(37,99,235,.10)}\n.hp-button{min-height:36px;border-color:var(--app-line-strong);border-radius:9px;background:#fff;color:#334155;font-weight:650}\n.hp-button:hover{border-color:#93b4ec;background:var(--app-primary-soft);color:var(--app-primary)}\n.hp-metric-grid{grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}\n.hp-metric{min-height:92px;padding:16px;border:1px solid var(--app-line);border-left:0;border-radius:12px;background:#fff;box-shadow:0 4px 14px rgba(15,23,42,.04)}\n.hp-metric::before{content:\"\";display:block;width:32px;height:3px;margin-bottom:13px;border-radius:999px;background:var(--hp-intent,var(--app-primary))}\n.hp-metric-label{margin-bottom:5px;color:#64748b;font-size:10px;font-weight:750;letter-spacing:.07em}\n.hp-metric-value{font-size:26px;font-weight:760;letter-spacing:-.025em}\n.hp-table-wrap{border-color:var(--app-line);border-radius:10px}\n.hp-table thead{top:0}\n.hp-table th{padding:10px 12px;background:#f8fafc;border-color:var(--app-line);color:#475569;font-size:10px;font-weight:750;text-transform:uppercase;letter-spacing:.06em}\n.hp-table td{padding:9px 12px;border-color:#edf1f5;font-size:12px}\n.hp-table tbody tr:hover td{background:#f8fbff}\n.hp-table tbody tr.hp-row-selected td{background:#eff6ff}\n.hp-table tbody tr.hp-row-selected td:first-child{box-shadow:inset 3px 0 0 var(--app-primary)}\n.hp-chips{min-height:0;padding:0;background:transparent;border:0;box-shadow:none}\n.hp-chip{padding:5px 9px;border-color:#bfdbfe;background:#eff6ff;color:#1d4ed8;font-size:10px;font-weight:650}\n.hp-collapsible{overflow:hidden;border:1px solid var(--app-line);border-radius:10px;background:#fff;box-shadow:none}\n.hp-collapse-button{padding:10px 11px;color:#334155;font-size:11px;font-weight:700}\n.hp-collapse-button:hover{background:#f8fafc}\n.hp-collapse-content{padding:0 10px 11px}\n.hp-drawer{max-width:100%;border-color:var(--app-line);border-radius:10px;box-shadow:none}\n.hp-drawer>header{min-height:40px;padding:8px 10px;background:#f8fafc}\n.hp-drawer-body{max-height:52vh;padding:10px}\n.hp-stat-list>div{padding:8px 0;border-color:#ed