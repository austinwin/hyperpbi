        "internalScope": "all",
        "externalMode": "filter",
        "field": "hyperpbi_general_enterprise_demo_dataset_category",
        "operator": "contains",
        "selectionMode": "replace",
        "multiSelect": false,
        "showSelector": false,
        "clearOnSecondClick": true
      },
      "field": "hyperpbi_general_enterprise_demo_dataset_category",
