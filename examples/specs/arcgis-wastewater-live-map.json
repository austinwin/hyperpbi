{
  "version": "2.0",
  "title": "Public ArcGIS reference layer",
  "components": [
    {
      "id": "wastewater-map",
      "type": "map",
      "title": "Houston Wastewater Network",
      "view": {
        "center": [
          29.75,
          -95.35
        ],
        "zoom": 12,
        "minZoom": 8,
        "maxZoom": 18,
        "fitMode": "none"
      },
      "basemap": {
        "type": "osm"
      },
      "layers": [
        {
          "id": "wastewater-layer",
          "name": "Wastewater UN Public",
          "source": {
            "type": "arcgisFeature",
            "url": "https://geogimstest.houstontx.gov/arcgis/rest/services/HW/WastewaterUNPublic/MapServer/9",
            "useServiceRenderer": true,
            "useServiceLabels": false,
            "mode": "reference",
            "outFields": [
              "OBJECTID",
              "FACILITYID",
              "DIAMETER",
              "MATERIAL",
              "INSTALLDATE"
            ]
          },
          "performance": {
            "maxFeatures": 2000,
            "requestBatchSize": 500,
            "viewportQuery": true,
            "cacheMinutes": 0
          },
          "popup": {
            "enabled": true,
            "title": "Wastewater Pipe {{FACILITYID}}",
            "fields": [
              {
                "field": "FACILITYID",
                "label": "Facility ID",
                "display": "text"
              },
              {
                "field": "DIAMETER",
                "label": "Diameter (in)",
                "display": "number"
              },
              {
                "field": "MATERIAL",
                "label": "Material",
                "display": "badge"
              },
              {
                "field": "INSTALLDATE",
                "label": "Install Date",
                "display": "date"
              }
            ]
          },
          "tooltip": {
            "enabled": true,
            "fields": [
              {
                "field": "FACILITYID",
                "fieldSource": "service",
                "label": "Facility"
              },
              {
                "field": "DIAMETER",
                "fieldSource": "service",
                "label": "Diameter"
              }
            ]
          },
          "labels": {
            "enabled": false
          },
          "legend": {
            "visible": true,
            "title": "Pipe Material"
          },
          "opacity": 0.85,
          "visible": true,
          "order": 1
        }
      ],
      "layerPanel": {
        "visible": true,
        "position": "right",
        "defaultOpen": false,
        "allowViewerReorder": true,
        "allowViewerOpacity": true,
        "allowViewerLabels": true
      },
      "search": {
        "enabled": true,
        "placeholder": "Search for a place or address",
        "zoom": 16,
        "showResultMarker": true
      },
      "legend": {
        "defaultOpen": true
      },
      "toolbar": {
        "visible": true,
        "home": true,
        "layers": true,
        "legend": true,
        "search": true,
        "clearSelection": true,
        "zoomToSelection": true
      }
    }
  ]
}
