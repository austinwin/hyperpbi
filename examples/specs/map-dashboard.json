{
  "version": "2.0",
  "title": "Asset Geography",
  "components": [
    {
      "type": "map",
      "id": "asset_map",
      "title": "Assets",
      "span": 8,
      "height": 420,
      "layers": [
        {
          "id": "asset_map-powerbi",
          "name": "Assets",
          "source": {
            "type": "powerbi",
            "bindings": {
              "latitude": "latitude",
              "longitude": "longitude"
            }
          },
          "renderer": {
            "type": "simple",
            "symbol": {
              "shape": "circle",
              "fillColor": "#206bc4",
              "outlineColor": "#206bc4",
              "size": 4,
              "fillOpacity": 0.7,
              "opacity": 1,
              "weight": 1
            }
          }
        }
      ],
      "view": {
        "fitMode": "data"
      },
      "featureDetails": {
        "mode": "auto"
      }
    },
    {
      "type": "table",
      "id": "map_details",
      "title": "Selected Geography",
      "columns": [
        "asset_id",
        "status",
        "latitude",
        "longitude"
      ],
      "pagination": true,
      "span": 4,
      "interaction": {
        "enabled": true,
        "internalMode": "filter",
        "externalMode": "selection",
        "showSelector": true
      }
    }
  ]
}
