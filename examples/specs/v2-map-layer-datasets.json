{
  "version": "2.0",
  "title": "Two logical map-layer views",
  "data": {"datasets": {
    "activeFacilities": {"source": "powerbi", "filter": {"field": "facilityStatus", "operator": "!=", "value": "Retired"}},
    "recentIncidents": {"source": "powerbi", "filter": {"field": "incidentAgeDays", "operator": "<=", "value": 30}}
  }},
  "components": [{
    "type": "map", "id": "dataset_map", "title": "Layer datasets",
    "layers": [
      {"id": "facilities", "name": "Active facilities", "dataset": "activeFacilities", "source": {"type": "powerbi", "bindings": {"latitude": "facilityLatitude", "longitude": "facilityLongitude"}}},
      {"id": "incidents", "name": "Recent incidents", "dataset": "recentIncidents", "source": {"type": "powerbi", "bindings": {"latitude": "incidentLatitude", "longitude": "incidentLongitude"}}}
    ]
  }]
}
