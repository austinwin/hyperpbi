{
  "version": "2.0",
  "title": "Public ArcGIS join layer — bind FacilityID through Values",
  "description": "Bind the Power BI FacilityID field through Values; the layer joins those rows to public ArcGIS pipe geometry.",
  "components": [
    {
      "id": "wastewater-join",
      "type": "map",
      "title": "Wastewater Join Map",
      "view": {
        "center": [29.75, -95.35],
        "zoom": 12
      },
      "basemap": {
        "type": "osm"
      },
      "layers": [
        {
          "id": "powerbi-join-layer",
          "name": "Work Orders with Pipe Geometry",
          "dataset": "powerbi",
          "source": {
            "type": "arcgisFeature",
            "url": "https://geogimstest.houstontx.gov/arcgis/rest/services/HW/WastewaterUNPublic/MapServer/9",
            "mode": "join",
            "outFields": ["FACILITYID", "DIAMETER", "MATERIAL", "INSTALLDATE"]
          },
          "join": {
            "enabled": true,
            "powerBiField": "FacilityID",
            "serviceField": "FACILITYID",
            "cardinality": "manyToOne",
            "keyType": "string",
            "normalization": ["trim", "upper"],
            "powerBiDuplicatePolicy": "first",
            "serviceDuplicatePolicy": "first",
            "unmatchedPolicy": "diagnose",
            "queryStrategy": "keyBatches"
          },
          "renderer": {
            "type": "uniqueValue",
            "field": "MATERIAL",
            "fieldSource": "service",
            "values": [
              { "value": "CI", "symbol": { "color": "#2c3e50", "fillOpacity": 0.4, "weight": 2 } },
              { "value": "PVC", "symbol": { "color": "#3498db", "fillOpacity": 0.4, "weight": 2 } },
              { "value": "RCP", "symbol": { "color": "#95a5a6", "fillOpacity": 0.4, "weight": 2 } }
            ],
            "defaultSymbol": { "color": "#e74c3c", "fillOpacity": 0.3, "weight": 1 }
          },
          "performance": {
            "maxFeatures": 2000,
            "requestBatchSize": 100,
            "viewportQuery": false,
            "cacheMinutes": 10
          },
          "popup": {
            "enabled": true,
            "title": "Work Order + Pipe {{FACILITYID}}",
            "fields": [
              { "field": "FacilityID", "fieldSource": "powerbi", "label": "Work Order ID" },
              { "field": "FACILITYID", "fieldSource": "service", "label": "Pipe ID" },
              { "field": "MATERIAL", "fieldSource": "service", "label": "Material" },
              { "field": "DIAMETER", "fieldSource": "service", "label": "Diameter" }
            ]
          },
          "tooltip": {
            "enabled": true,
            "fields": [
              { "field": "FacilityID", "fieldSource": "powerbi", "label": "Power BI Facility" },
              { "field": "FACILITYID", "fieldSource": "service", "label": "Service Facility" }
            ]
          },
          "labels": {
            "enabled": false
          },
          "legend": {
            "visible": true,
            "title": "Pipe Material"
          },
          "opacity": 0.85,
          "visible": true,
          "order": 1
        }
      ],
      "layerPanel": {
        "visible": true,
        "position": "right",
        "defaultOpen": false,
        "allowViewerReorder": true,
        "allowViewerOpacity": true,
        "allowViewerLabels": true
      },
      "search": {
        "enabled": true,
        "placeholder": "Search for a place or address",
        "zoom": 16,
        "showResultMarker": true
      },
      "legend": { "defaultOpen": false },
      "toolbar": {
        "visible": true,
        "home": true,
        "layers": true,
        "legend": true,
        "search": true,
        "clearSelection": true,
        "zoomToSelection": true
      },
      "settings": {
        "showLayerControl": true,
        "showLegend": true
      }
    }
  ]
}
