      "fill": { "bind": "status", "map": { "On Track": "#16a34a", "Watch": "#d97706", "At Risk": "#dc2626" }, "fallback": "#64748b" }, "ariaLabel": "Status mark", "interaction": { "enabled": true, "internalMode": "highlight", "externalMode": "selection", "field": "status", "selectionMode": "replace" }
