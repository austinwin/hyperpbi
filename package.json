{
  "name": "hyperpbi",
  "description": "AI-native analytics runtime and portable dashboard specification for Power BI and the web",
  "version": "1.0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/austinwin/hyperpbi.git"
  },
  "homepage": "https://hyperpbi.com",
  "license": "Apache-2.0",
  "scripts": {
    "pbiviz": "pbiviz",
    "start": "pbiviz start",
    "package": "npm run package:core",
    "package:core": "node scripts/package-profile.mjs core",
    "package:maps": "node scripts/package-profile.mjs maps",
    "package:verify": "node scripts/verify-package-capabilities.mjs",
    "docs:generate": "node scripts/generate-documentation.mjs",
    "docs:check": "node scripts/generate-documentation.mjs --check",
    "schema:migrate-v1": "node scripts/migrate-schema-v1-to-v2.mjs",
    "dev": "npm run playground:dev",
    "build": "npm run typecheck && npm run playground:typecheck && npm run playground:build",
    "certification:audit": "node scripts/package-profile.mjs core audit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "playwright test",
    "lint": "eslint .",
    "playground:dev": "vite --config apps/playground/vite.config.mts",
    "playground:typecheck": "tsc -p apps/playground/tsconfig.json --noEmit",
    "playground:test": "vitest run tests/file-import.test.ts tests/data-workspace.test.ts tests/browser-host.test.ts tests/project-storage.test.ts tests/playground-export.test.ts tests/powerbi-portability.test.ts tests/playground-play-mode.test.tsx",
    "playground:test:browser": "playwright test --config apps/playground/playwright.config.ts",
    "playground:build": "vite build --config apps/playground/vite.config.mts",
    "playground:preview": "vite preview --config apps/playground/vite.config.mts"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@e965/xlsx": "^0.20.3",
    "@tabler/core": "^1.4.0",
    "@types/d3": "7.4.3",
    "ajv": "^8.20.0",
    "codemirror": "^6.0.2",
    "css-tree": "^3.2.1",
    "d3": "7.9.0",
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "powerbi-visuals-api": "~5.11.0",
    "powerbi-visuals-utils-formattingmodel": "6.0.4",
    "preact": "^10.29.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@preact/preset-vite": "^2.10.2",
    "@types/css-tree": "^2.3.11",
    "@types/jsdom": "^28.0.3",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "eslint": "^9.11.1",
    "eslint-plugin-powerbi-visuals": "^1.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.1.3",
    "powerbi-visuals-tools": "^6.1.3",
    "typescript": "5.5.4",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
